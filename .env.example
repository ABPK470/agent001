PORT=3102
HOST=0.0.0.0

# ── Agent workspace ───────────────────────────────────────────────
# Directory where the agent reads/writes files and runs shell commands.
# Defaults to the git repo root if unset.
AGENT_WORKSPACE=/path/to/your/project
AGENT_HOSTED_MODE=false # false: runs on host, false: runs in docker sandbox

# ── Sandbox mode ─────────────────────────────────────────────────
# docker  — shell commands run in isolated Docker containers (default)
# host    — shell commands run on the host (no Docker required)
# all     — ALL commands go through Docker; fails if Docker unavailable
SANDBOX_MODE=host

# ── Concurrency ───────────────────────────────────────────────────
# Max number of agent runs executing in parallel.
MAX_CONCURRENT_RUNS=5


# ── Run workspace isolation ───────────────────────────────────────
# Set to false to disable per-run workspace copies (faster but less isolated).
# AGENT_ISOLATED_WORKSPACE=true

# ── Data directory (set before first start) ───────────────────────
# All server runtime state: SQLite, catalog cache, sync-plan disk cache,
# evidence, attachments, browser contexts, vault key.
#
# REQUIRED for production / Windows Server — pick a dedicated folder on a data
# drive with backup and ACLs under your control. If unset, defaults to ~/.mia/
# (on Windows: C:\Users\<account>\.mia — avoid that for a Windows service).
#
# Linux / macOS example:
MIA_DATA_DIR=/var/lib/mia
#
# Windows example (forward slashes work in .env):
# MIA_DATA_DIR=D:/mia/data
#
# First install: run `npm run setup` (wizard writes this file). Validate anytime:
#   npm run setup -- --check

# Skip startup pre-flight checks (CI / automated tests only)
# MIA_SKIP_SETUP=1

# ── MSSQL (optional) ─────────────────────────────────────────────
#
# MODE 1 — Single database (current setup, uses the vars below)
#   Set MSSQL_HOST and the server connects to that one DB.
#   MSSQL_DOMAIN enables Windows/NTLM authentication.
#
MSSQL_HOST=zauyn1msql00004.corp.dsarena.com
MSSQL_PORT=10111
MSSQL_DATABASE=mymi
MSSQL_ENCRYPT=false
MSSQL_TRUST_CERT=true
MSSQL_DOMAIN=corp
MSSQL_USER=
MSSQL_PASSWORD=

# MODE 2 — Multiple databases (MSSQL_DATABASES JSON array, overrides MODE 1)
#   Each entry needs: name, host, database. Optional: port, user, password, domain,
#   encrypt, trustServerCertificate, writeEnabled, knowledgePath.
#   Example:
# 
# MSSQL_DATABASES=[{"name":"prod","host":"sqlprod","database":"mymi","domain":"corp"},{"name":"uat","host":"sqluat","database":"mymi","domain":"corp"}]
#
# When using multi-database mode, set the default connection the agent uses for
# all regular queries (search_catalog, query_mssql, etc.) unless the task
# explicitly targets a different environment (e.g. sync operations).
MSSQL_DEFAULT_CONNECTION=dev


# Database knowledge file — a Markdown file describing the database schema,
# business context, and domain meaning. Injected into the system prompt so
# the agent understands the database structure without runtime discovery.
MSSQL_KNOWLEDGE_FILE=./deploy/mssql/mymi-knowledge.md

# Tenant config — JSON settings for this mia server install (one file per
# deployment). Controls mirror detection, goal routing, SQL validators, and
# catalog search ranking. NOT the same as mymi-knowledge.md (prose for the LLM).
# Copy packages/agent/config/tenant.example.json → deploy/tenant.json (or your path).
# See packages/agent/config/TENANT-CONFIG.md
MIA_TENANT_CONFIG=./deploy/tenant.json

# ── Databricks (optional) ───────────────────────────────────────
# Set when using Databricks as the LLM provider.
DATABRICKS_HOST=https://databricks.example.com
DATABRICKS_CLIENT_ID=1234567890
DATABRICKS_CLIENT_SECRET=1234567890

# ── LLM provider (required) ─────────────────────────────────────
# Written into SQLite llm_config on every server boot.
#
# copilot-chat → LLM_MODEL is the model id (default gpt-5.4)
# databricks   → LLM_MODEL is the serving endpoint name (default databricks-gpt-5-4)
LLM_PROVIDER=copilot-chat
LLM_MODEL=gpt-5.4
