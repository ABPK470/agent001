          "title": "Metadata sync",
          "description": "Apply transactional metadata changes for the selected content scope."
        },
        {
          "id": "handleDependencies",
          "phase": "postMetadata",
          "kind": "handleDependencies",
          "title": "Handle dependencies",
          "description": "Refresh downstream content dependency state.",
