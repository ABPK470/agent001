# ── Dependencies ─────────────────────────────────────────────────
node_modules

# ── Build output ─────────────────────────────────────────────────
dist
*.tsbuildinfo
coverage

# ── Runtime data (catalog caches, sync-plan snapshots, queues) ───
# Each package writes its own state under packages/<name>/data/.
# These are environment-specific and must never be committed.
packages/*/data/

# ── Environment / secrets ────────────────────────────────────────
.env
.env.local
.env.*.local
.npmrc

# ── Editor / OS ──────────────────────────────────────────────────
.vscode
.idea
.DS_Store
*.swp

# ── Logs / caches / scratch ──────────────────────────────────────
*.log
*.cache
/tmp

# ── Personal scratch (kept local, not shared) ────────────────────
notes
docs
