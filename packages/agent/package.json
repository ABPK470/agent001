    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@mia/shared-types": "*",
    "@mia/sync": "*",
    "@mia/shared-enums": "*",
    "mssql": "^12.2.1",
    "playwright": "^1.49.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@types/mssql": "^9.1.11",
    "@types/node": "^22.16.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
