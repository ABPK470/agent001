{
  "name": "@mia/agent",
  "version": "0.1.0",
  "description": "A real AI agent with tools — LLM decides what to do, calls tools, observes results, repeats until done.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./application": "./src/application/index.ts",
    "./application/core": "./src/application/core/index.ts",
    "./application/core/clarify": "./src/application/core/clarify.ts",
    "./application/core/doctrine": "./src/application/core/doctrine.ts",
    "./application/core/governance": "./src/application/core/governance.ts",
    "./application/core/planner": "./src/application/core/planner.ts",
    "./application/core/planner-routing": "./src/application/core/planner-routing.ts",
    "./application/core/recovery": "./src/application/core/recovery.ts",
    "./application/shell": "./src/application/shell/index.ts",
    "./application/shell/agent": "./src/application/shell/agent.ts",
    "./application/shell/delegation": "./src/application/shell/delegation.ts",
    "./application/shell/loop": "./src/application/shell/loop.ts",
    "./application/shell/runtime": "./src/application/shell/runtime.ts",
    "./domain": "./src/domain/index.ts",
    "./ports": "./src/ports/index.ts",
    "./tools": "./src/tools/index.ts",
    "./memory": "./src/memory/index.ts",
    "./llm": "./src/llm/index.ts",
    "./internal": "./src/internal/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
