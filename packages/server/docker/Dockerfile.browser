# Minimal Node + Chromium image for sandboxed browser checks.
# Built on-demand by the sandbox service. Cached after first build.
#
# Based on node:20-slim with Chromium from Debian repos.
# Total size: ~400MB (vs ~1.5GB for full Puppeteer image).

FROM node:20-slim

# Install Chromium and dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    chromium \
    fonts-liberation \
    libdrm2 \
    libgbm1 \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libnspr4 \
    libnss3 \
    libx11-xcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    xvfb \
    && rm -rf /var/lib/apt/lists/*

# Tell Puppeteer to use system Chromium (don't download its own)
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
ENV CHROME_BIN=/usr/bin/chromium

# Install puppeteer (just the Node package, no browser download)
RUN npm install -g puppeteer@latest --unsafe-perm

# Non-root user for execution
USER node
WORKDIR /workspace
