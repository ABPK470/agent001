# Browser sandbox image — Playwright + Chromium pre-bundled.
# Built on-demand by the sandbox service. Cached after first build.
#
# Based on Microsoft's official Playwright image which already includes:
#   - Node.js 20
#   - Chromium (matched to playwright version)
#   - All required system libs (libnss3, libgbm1, fonts, etc.)
#   - xvfb for visible-mode handoff
#
# This image also installs x11vnc + websockify so the agent can hand a
# *visible* browser session over to the human user via a noVNC URL when
# CAPTCHA / non-TOTP 2FA blocks automation. The browser keeps running
# inside the sandbox; only the framebuffer is streamed.
#
# Pin the playwright image tag to the same version as packages/agent's
# `playwright` dep to guarantee API compatibility.
FROM mcr.microsoft.com/playwright:v1.49.0-jammy

# Install the VNC + websockify bridge for human-handoff. websockify is
# tiny (Python) and exposes the x11vnc TCP port over WebSocket so the UI
# can stream it directly through the server's reverse-proxy without any
# 3rd-party service. novnc itself is served as static assets by the
# server (see packages/ui/public/novnc/), keeping the sandbox image lean.
USER root
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        x11vnc \
        websockify \
        xvfb \
 && rm -rf /var/lib/apt/lists/*

# Playwright base image already installs the playwright npm package globally
# under /ms-playwright. We re-export the env explicitly for clarity.
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
ENV NODE_PATH=/usr/lib/node_modules

# Default DISPLAY for visible-mode launches. The orchestrator script
# starts xvfb on this display before launching chromium with
# `headless: false`. x11vnc then mirrors :99 to TCP 5900 and websockify
# bridges it to WS 6080 — the server proxies that WS over /api/browser/handoff.
ENV DISPLAY=:99
ENV VNC_PORT=5900
ENV NOVNC_WS_PORT=6080

# Non-root user for execution (provided by the playwright base image as `pwuser`)
USER pwuser
WORKDIR /workspace

