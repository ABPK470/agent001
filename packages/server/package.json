{
  "name": "@mia/server",
  "version": "0.1.0",
  "description": "MI:A command center — server with persistence, real-time updates, and agent orchestration.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./bootstrap": "./src/bootstrap/index.ts",
    "./bootstrap/boot-host-adapter": "./src/bootstrap/boot-host-adapter.ts",
    "./bootstrap/llm": "./src/bootstrap/llm.ts",
    "./bootstrap/sync": "./src/bootstrap/sync.ts",
    "./features/runs/workspace": "./src/features/runs/workspace/index.ts",
    "./features": "./src/features/index.ts",
    "./platform": "./src/platform/index.ts",
    "./platform/effects": "./src/platform/effects/index.ts",
    "./platform/events": "./src/platform/events/broadcaster.ts",
    "./platform/llm": "./src/platform/llm/index.ts",
    "./platform/mssql": "./src/platform/mssql/setup.ts",
    "./platform/persistence": "./src/platform/persistence/index.ts",
    "./platform/sandbox": "./src/platform/sandbox/index.ts",
    "./ports": "./src/ports/index.ts",
    "./shared": "./src/shared/index.ts",
    "./shared/enums": "./src/shared/enums/index.ts",
    "./shared/utils/vault": "./src/shared/utils/vault.ts"
  },
  "scripts": {
    "build": "tsc",
    "predev": "node ../../scripts/ensure-native-modules.mjs",
    "dev": "tsx watch src/index.ts",
    "entity-registry:export": "tsx src/cli/export-entity-registry.ts",
    "setup": "tsx src/cli/setup-main.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "db:status": "tsx src/cli/db-status.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.3",
    "@fastify/static": "^8.0.4",
    "@mia/agent": "*",
    "@mia/sync": "*",
    "@mia/shared-enums": "*",
    "@mia/shared-types": "*",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.3.3",
    "otplib": "^13.4.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.16.4",
    "tsx": "^4.7.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
