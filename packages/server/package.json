{
  "name": "@mia/server",
  "version": "0.1.0",
  "description": "MI:A command center — server with persistence, real-time updates, and agent orchestration.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./boot": "./src/boot/index.ts",
    "./boot/llm": "./src/boot/llm.ts",
    "./adapters": "./src/adapters/index.ts",
    "./adapters/agent/boot-host-deps": "./src/adapters/agent/boot-host-deps.ts",
    "./adapters/sync/sinks": "./src/adapters/sync/sinks.ts",
    "./api": "./src/api/index.ts",
    "./api/runs/workspace": "./src/api/runs/workspace/index.ts",
    "./infra": "./src/infra/index.ts",
    "./infra/effects": "./src/infra/effects/index.ts",
    "./infra/events": "./src/infra/events/broadcaster.ts",
    "./infra/llm": "./src/infra/llm/index.ts",
    "./infra/mssql": "./src/infra/mssql/setup.ts",
    "./infra/persistence": "./src/infra/persistence/index.ts",
    "./infra/sandbox": "./src/infra/sandbox/index.ts",
    "./ports": "./src/ports/index.ts",
    "./internal": "./src/internal/index.ts",
    "./internal/enums": "./src/internal/enums/index.ts",
    "./internal/utils/vault": "./src/internal/utils/vault.ts"
  },
  "scripts": {
    "build": "tsc",
    "predev": "node ../../scripts/ensure-native-modules.mjs",
    "dev": "tsx watch src/index.ts",
    "entity-registry:export": "tsx src/cli/export-entity-registry.ts",
    "export-deploy-catalog": "tsx src/cli/export-deploy-catalog.ts",
    "setup": "tsx src/cli/setup-main.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "db:status": "tsx src/cli/db-status.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.3",
    "@fastify/static": "^8.0.4",
    "@mia/agent": "*",
    "@mia/sync": "*",
    "@mia/connectors": "*",
    "@mia/shared-enums": "*",
    "@mia/shared-types": "*",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.3.3",
    "otplib": "^13.4.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.16.4",
    "tsx": "^4.7.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
